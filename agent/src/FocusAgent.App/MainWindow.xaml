<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FocusAgent.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="FocusAgent" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1" Text="Idle. No active session." Opacity="0.7" />
    </Grid>
</Window>
